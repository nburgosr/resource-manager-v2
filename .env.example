# Base de datos PostgreSQL
# Vercel Postgres genera estas variables automáticamente al vincular la base de datos.
# DATABASE_URL         = conexión pooled (pgbouncer) — usada por la app en runtime.
# POSTGRES_URL_NON_POOLING = conexión directa — usada por Prisma para migraciones.
DATABASE_URL="postgresql://user:password@host:5432/dbname?sslmode=require"
POSTGRES_URL_NON_POOLING="postgresql://user:password@host:5432/dbname?sslmode=require"

# NextAuth — genera un secreto seguro con: openssl rand -base64 32
AUTH_SECRET="cambia-esto-por-un-secreto-seguro"

# URL pública de la aplicación (requerida por NextAuth en producción)
NEXTAUTH_URL="https://tu-app.vercel.app"

# Usuario administrador (lectura y escritura)
ADMIN_EMAIL="admin@tudominio.com"
ADMIN_PASSWORD="cambia-esta-contrasena"
ADMIN_NAME="Administrador"

# Usuario de solo lectura (opcional)
VIEWER_EMAIL="viewer@tudominio.com"
VIEWER_PASSWORD="cambia-esta-contrasena"
VIEWER_NAME="Visualizador"
